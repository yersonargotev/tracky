{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yersonargotev/tracky/evidence/dashboard/manual-accessibility.schema.json",
  "title": "Tracky dashboard manual accessibility submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "commit", "lockfile_sha256", "candidate_run_id", "candidate_run_url", "responsible_maintainer", "maintainer_sign_off", "platforms"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "lockfile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_run_id": {"type": "integer", "minimum": 1},
    "candidate_run_url": {"type": "string", "pattern": "^https://github\\.com/yersonargotev/tracky/actions/runs/[1-9][0-9]*$"},
    "responsible_maintainer": {"type": "string", "minLength": 1},
    "maintainer_sign_off": {"$ref": "#/$defs/signOff"},
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["safari-voiceover", "firefox-orca"],
      "properties": {
        "safari-voiceover": {"$ref": "#/$defs/platform"},
        "firefox-orca": {"$ref": "#/$defs/platform"}
      }
    }
  },
  "$defs": {
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "target", "operating_system", "browser", "assistive_technology", "artifact", "tester", "date", "checks", "sign_off"],
      "properties": {
        "environment": {"type": "string", "minLength": 1},
        "target": {"enum": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"]},
        "operating_system": {"type": "string", "minLength": 1},
        "browser": {"$ref": "#/$defs/versionedTool"},
        "assistive_technology": {"$ref": "#/$defs/versionedTool"},
        "artifact": {
          "type": "object", "additionalProperties": false,
          "required": ["name", "sha256"],
          "properties": {
            "name": {"type": "string", "pattern": "^tracky-(aarch64-apple-darwin|x86_64-unknown-linux-gnu)\\.tar\\.xz$"},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "tester": {"type": "string", "minLength": 1},
        "date": {"type": "string", "format": "date"},
        "checks": {"type": "array", "minItems": 10, "maxItems": 10, "uniqueItems": true, "items": {"$ref": "#/$defs/check"}},
        "sign_off": {"$ref": "#/$defs/signOff"}
      }
    },
    "versionedTool": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}
    },
    "check": {
      "type": "object", "additionalProperties": false,
      "required": ["check", "status", "findings", "evidence"],
      "properties": {
        "check": {"type": "string", "minLength": 1},
        "status": {"enum": ["not_run", "pass", "fail"]},
        "findings": {"type": "string"},
        "evidence": {"type": "string"}
      }
    },
    "signOff": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "signed_by", "signed_at"],
      "properties": {
        "status": {"enum": ["not_run", "pass", "fail"]},
        "signed_by": {"type": "string"},
        "signed_at": {"type": "string"}
      }
    }
  }
}
